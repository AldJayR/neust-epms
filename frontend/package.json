{
  "name": "frontend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- node --import ./instrument.server.mjs ./node_modules/vite/bin/vite.js dev --port 3000",
    "build": "vite build && node -e \"const fs = require('node:fs'); fs.mkdirSync('.output/server', { recursive: true }); fs.copyFileSync('instrument.server.mjs', '.output/server/instrument.server.mjs')\"",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/roboto": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/tanstackstart-react": "^10.52.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.167.35",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
